{
    "$schema": "https://raw.githubusercontent.com/infection/infection/0.32.x/resources/schema.json",
    "source": {
        "directories": [
            "src"
        ],
        "excludes": [
            "Interfaces"
        ]
    },
    "timeout": 60,
    "logs": {
        "text": "infection.log",
        "summary": "infection-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 96,
    "minCoveredMsi": 100,
    "phpUnit": {
        "configDir": "."
    }
}
